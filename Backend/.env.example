# Unified LMS backend — copy to .env and adjust.
# One Express app serves BOTH the branding subsystem (JSON store) and the course subsystem (MongoDB + S3).

# Port for the whole API. Avoid 6000 — browsers block it (net::ERR_UNSAFE_PORT, the X11 port).
PORT=8080

# ── Auth (shared secret for both subsystems' JWTs) ──
JWT_SECRET=dev-super-secret-change-me
JWT_EXPIRES_IN=7d

# ── Branding subsystem ──
# Default tenant used when a request omits the X-Tenant-Code header.
DEFAULT_TENANT=calcite
# Allowed frontend origins (CORS) — the branding/portal frontend dev server.
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180

# ── Course subsystem (MongoDB) ──
MONGODB_URI=mongodb://127.0.0.1:27017/calcite_courses

# ── Course subsystem (AWS S3 — lesson uploads, signed URLs, certificate PDFs) ──
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=your-bucket-name
