{
  "name": "lms-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Unified LMS backend — branding (JSON store) + course system (MongoDB + S3), one Express app.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed:branding": "node services/brandingStore.js --seed",
    "seed:course": "node scripts/seedCourseUsers.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.984.0",
    "@aws-sdk/s3-request-presigner": "^3.984.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "pdfkit": "^0.15.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
