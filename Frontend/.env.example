# Copy to .env and adjust. Vite exposes only VITE_* vars to the app (import.meta.env).
# Restart `npm run dev` after changing this file.

# Backend API base URL (must include the /api prefix). Used by src/lib/api.js as the request base.
# In dev you can either point straight at the backend (below) or leave it unset to use the relative
# "/api" served through the Vite dev proxy (see vite.config.js → proxy target http://localhost:6000).
VITE_API_URL=http://localhost:8080/api

# The X-Tenant-Code sent with every request (also overridable at runtime via localStorage 'uc.tenant').
VITE_TENANT_CODE=calcite
